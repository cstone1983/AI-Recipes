generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String       @id @default(uuid())
  email               String       @unique
  username            String       @unique
  password            String
  role                String       @default("User")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  exportIncludeImages Boolean      @default(true)
  exportCompactLayout Boolean      @default(false)
  exportLargeFont     Boolean      @default(false)
  showNutrition       Boolean      @default(true)
  friendsReceived     Friendship[] @relation("FriendReceiver")
  friendsInitiated    Friendship[] @relation("FriendInitiator")
  recipes             Recipe[]
  sessions            Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id          String   @id @default(uuid())
  initiatorId String
  receiverId  String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  receiver    User     @relation("FriendReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  initiator   User     @relation("FriendInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)

  @@unique([initiatorId, receiverId])
}

model Recipe {
  id           String       @id @default(uuid())
  title        String
  description  String?
  prepTime     Int?
  cookTime     Int?
  yield        String?
  instructions String
  imageUrl     String?
  visibility   String       @default("Private")
  category     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  authorId     String
  calories     Int?
  protein      Float?
  carbs        Float?
  fat          Float?
  fiber        Float?
  saturatedFat Float?
  transFat     Float?
  cholesterol  Float?
  sodium       Float?
  sugar        Float?
  addedSugar   Float?
  vitaminD     Float?
  calcium      Float?
  iron         Float?
  potassium    Float?
  ingredients  Ingredient[]
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags         Tag[]        @relation("RecipeToTag")
}

model Ingredient {
  id       String  @id @default(uuid())
  name     String
  amount   Float?
  unit     String?
  notes    String?
  recipeId String
  recipe   Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Tag {
  id      String   @id @default(uuid())
  name    String   @unique
  recipes Recipe[] @relation("RecipeToTag")
}

model GlobalConfig {
  id           String  @id @default("default")
  geminiApiKey String?
  geminiModel  String  @default("gemini-3-flash-preview")
  updateUrl    String? @default("https://raw.githubusercontent.com/cstone1983/AI-Recipes/main/version.json")
}
